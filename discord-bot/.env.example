# ── Required ──────────────────────────────────────────────────────────────────
# Bot token from the Discord Developer Portal (Bot → Reset Token)
DISCORD_TOKEN=your-bot-token-here
# Application ID (Developer Portal → General Information → Application ID)
CLIENT_ID=your-application-id-here
# A valid staff key (LVNT-STAFF-XXXXXXXX-YYYYMMDD). Authorizes every key action.
# Get one from the app's Staff tab, or run in the Supabase SQL editor:
#   select public.make_staff_key('20280101');
LVNT_STAFF_KEY=LVNT-STAFF-XXXXXXXX-YYYYMMDD
# The license key your alting PC's Leventia program is activated with. This is the
# deploy target for /deployalts /removealts /stopalts /altstatus.
WORKER_LICENSE_KEY=

# ── Recommended ───────────────────────────────────────────────────────────────
# Your server ID — registers slash commands instantly to just this server.
# Leave blank to register globally (can take up to 1 hour to show up).
GUILD_ID=
# Full-access role(s) — can run every command. Comma-separate for multiple.
# Leave blank to require the Discord "Administrator" permission instead.
ADMIN_ROLE_ID=
# Key-issuer role(s) — can use /genkey + /keyinfo ONLY (not revoke/extend/link).
# Comma-separate for multiple. Good for trusted sellers who only hand out keys.
KEY_ROLE_ID=
# Moderator role(s) — can use ban/kick/mute/unmute/unban/purge/warn ONLY.
# Comma-separate for multiple. Leave blank to allow only admins to moderate.
MOD_ROLE_ID=

# ── Tickets ───────────────────────────────────────────────────────────────────
# Channel where the "Open Ticket" panel is posted (defaults to the configured one).
TICKET_PANEL_CHANNEL_ID=1511076294849466602
# Optional: category ID that new ticket channels are created under. Blank = no category.
TICKET_CATEGORY_ID=
# Channel where ticket transcripts (.txt) + a close summary are logged. Blank = no logging.
TICKET_LOG_CHANNEL_ID=
# Role(s) that can see + claim tickets. Comma-separate. Blank = admins + mod roles.
SUPPORT_ROLE_ID=

# ── Staff promotions / demotions ──────────────────────────────────────────────
# Channel where /promote and /demote announcements are posted (override per-command
# with the optional "channel" option).
PROMO_CHANNEL_ID=1513285194847748157

# ── Website ───────────────────────────────────────────────────────────────────
# Download link shown by the /website command.
WEBSITE_URL=https://leventia-free-hub.lovable.app

# ── Pricing ───────────────────────────────────────────────────────────────────
# Channel the /price list is posted to. (Actual prices are edited in bot.js → PRICES.)
PRICE_CHANNEL_ID=1511075149682839653

# ── Optional (defaults match the desktop app; override only if you moved DBs) ──
# SUPABASE_URL=
# SUPABASE_KEY=
