{
  "name": "erlc-server-bot-v2",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "Discord bot for remotely managing an ER:LC (Emergency Response: Liberty County) private server via the PRC API.",
  "main": "bot.js",
  "scripts": {
    "start": "node bot.js",
    "bundle": "esbuild bot.js --bundle --platform=node --format=esm --packages=external --outfile=bundle/bot.js"
  },
  "dependencies": {
    "discord.js": "^14.26.4",
    "dotenv": "^16.4.5"
  },
  "engines": {
    "node": ">=18"
  },
  "devDependencies": {
    "esbuild": "^0.28.0"
  }
}
