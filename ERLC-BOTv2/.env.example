# ── Discord ─────────────────────────────────────────────────────────────────
# Bot token (Developer Portal → Bot → Reset Token). NEVER commit this.
DISCORD_TOKEN=your-bot-token-here
# Application ID (Developer Portal → General Information → Application ID)
CLIENT_ID=your-application-id-here
# Your server ID — registers slash commands instantly to just this server.
# Leave blank to register globally (can take up to 1 hour to appear).
GUILD_ID=

# ── ER:LC / PRC API ───────────────────────────────────────────────────────────
# Server key from the in-game settings (PRC API). Authorizes every ERLC action.
ERLC_SERVER_KEY=your-erlc-server-key-here
# Override only if PRC changes their base URL.
# ERLC_API_URL=https://api.erlc.gg/v1

# ── Permissions ───────────────────────────────────────────────────────────────
# Role(s) allowed to run staff commands (ERLC, sessions, infractions, etc.).
# Comma-separate for multiple. Leave blank to require Discord "Administrator".
STAFF_ROLE_ID=
# Role(s) allowed to run arbitrary raw in-game commands (u!run) + admin commands
# (close-all-tickets, setup, reset-config). Blank = Administrator only.
ADMIN_ROLE_ID=
# Role(s) allowed to issue /globalban across every server the bot is in.
# Blank = Administrator only. Set on your HQ server's staff role.
GLOBAL_BAN_ROLE_ID=

# ── Branding (defaults for every server; override per-server with /setup) ─────
# These power the Components V2 "Orlando-style" panels. All optional — panels
# render fine without them, just without images.
BRAND_NAME=
BRAND_FOOTER=
BRAND_COLOR=2b6cb0
# Full https URLs to images you host (Discord CDN, imgur, etc.)
BRAND_LOGO_URL=
BRAND_SEPARATOR_URL=
# Role pinged by session/training panels, and the Join Server button link.
COMMUNITY_ROLE_ID=
JOIN_URL=

# NOTE: per-panel banner images (Infractions/Promotions/Session Start/…) and all
# channel/role wiring are configured live with /setup — no .env needed.
